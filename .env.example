# ============================================================
# GrowEasy CSV Importer — centralized environment config
# ============================================================
# Copy this file to `.env` in the repo root. Both the backend and
# frontend read from THIS one file automatically — nothing else to touch.
#
#   cp .env.example .env
#
# Only one variable is required. Everything below it is optional and
# already has a working default (shown commented out).

# --- REQUIRED ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# --- Optional overrides (defaults shown, uncomment to change) ---

# AI model + Groq endpoint
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Batching for AI extraction calls
# AI_BATCH_SIZE=8
# AI_BATCH_RETRIES=1

# Ports (auto-wired between frontend <-> backend by start.sh / render.yaml)
# PORT=3000                 # public port the frontend binds to
# BACKEND_INTERNAL_PORT=4000 # internal-only port the backend listens on

# CORS allow-list for the backend, if you ever run frontend/backend as
# fully separate hosts instead of the combined single-service setup.
# FRONTEND_ORIGIN=http://localhost:3000
