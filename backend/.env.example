# Port the backend listens on locally (Render sets PORT itself in production)
PORT=4000

# Comma-separated list of allowed frontend origins for CORS.
# Leave unset/empty to allow same-origin/no-origin requests (e.g. server-to-server).
FRONTEND_ORIGIN=http://localhost:3000

# --- Groq (OpenAI-compatible) AI extraction ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides (defaults shown)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Batch size and retry count for AI extraction calls
AI_BATCH_SIZE=8
AI_BATCH_RETRIES=1
